# ============================================================================
# hostsblue — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# ---------- Core ----------
NODE_ENV=development
PORT=5001
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ---------- Database ----------
DATABASE_URL=postgresql://username:password@localhost:5432/hostsblue

# ---------- Authentication (JWT RS256) ----------
# Generate key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste inline with \n escapes, or set JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH
JWT_PRIVATE_KEY=dev-private-key
JWT_PUBLIC_KEY=dev-private-key
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=hostsblue.com
JWT_AUDIENCE=hostsblue.com

# ---------- Session ----------
SESSION_SECRET=your_session_secret_change_this_in_production

# ---------- CORS ----------
# Comma-separated list of allowed origins (defaults to CLIENT_URL + hostsblue.com)
ALLOWED_ORIGINS=http://localhost:5173,https://hostsblue.com

# ---------- Email (Resend) ----------
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@hostsblue.com

# ---------- Payment: SwipesBlue (default provider) ----------
ACTIVE_PAYMENT_PROVIDER=swipesblue
SWIPESBLUE_API_URL=https://api.swipesblue.com/v1
SWIPESBLUE_API_KEY=your_swipesblue_api_key
SWIPESBLUE_WEBHOOK_SECRET=your_webhook_secret
SWIPESBLUE_MERCHANT_ID=
SWIPESBLUE_WEBHOOK_URL=https://api.hostsblue.com/api/v1/webhooks/payment

# ---------- Payment: Stripe (optional) ----------
# Set ACTIVE_PAYMENT_PROVIDER=stripe to use Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Domain Registration (OpenSRS) ----------
OPENSRS_API_URL=https://horizon.opensrs.net:55443
OPENSRS_USERNAME=your_reseller_username
OPENSRS_API_KEY=your_private_api_key

# ---------- WordPress Hosting (WPMUDEV) ----------
WPMUDEV_API_KEY=your_wpmudev_api_key
WPMUDEV_API_URL=https://premium.wpmudev.org/api

# ---------- Email Hosting (OpenSRS) ----------
OPENSRS_EMAIL_API_URL=https://admin.test.hostedemail.com/api
OPENSRS_EMAIL_USER=your_email_reseller_user
OPENSRS_EMAIL_PASSWORD=your_email_reseller_password

# ---------- SSL Certificates (OpenSRS) ----------
OPENSRS_SSL_API_URL=
OPENSRS_SSL_API_KEY=

# ---------- Cloud Servers (Kamatera) ----------
KAMATERA_CLIENT_ID=your_kamatera_client_id
KAMATERA_SECRET=your_kamatera_secret
KAMATERA_DEFAULT_DATACENTER=US-NY2

# ---------- Security (SiteLock) ----------
SITELOCK_API_URL=https://api.sitelock.com/v1
SITELOCK_PARTNER_ID=your_partner_id
SITELOCK_PARTNER_KEY=your_partner_api_key

# ---------- AI Providers ----------
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# ---------- Credential Encryption ----------
# 32 bytes hex for AES-256-GCM
CREDENTIAL_ENCRYPTION_KEY=generate_a_32_byte_hex_key

# ---------- Custom Nameservers ----------
HOSTSBLUE_NS1=ns1.hostsblue.com
HOSTSBLUE_NS2=ns2.hostsblue.com

# ---------- Storage ----------
REPLIT_DB_URL=
